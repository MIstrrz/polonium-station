ent-TowelColorGoldUnfolded = złoty ręcznik
    .desc = Bardzo wszechstronny, ciężki złoty ręcznik. Obiecano ci płatny urlop. Zamiast tego dostałeś to.
ent-TowelColorGold = { ent-TowelColorGoldUnfolded }
